# Reports (private data — never committed, never pushed, always gitignored)
# Agents always write their output here, rooted at the MAIN project dir even
# inside worktrees. See skills/*/references/*.md for the orchestrator path
# resolution rules.
reports/

# Logs
*.log
logs/

# UV
# uv.lock is committed for reproducibility

# Rechecker plugin (auto-managed runtime state, overwrites tracked files)
.rechecker/

# Serena local config (per-machine settings, not for version control)
.serena/project.local.yml

# LLM Externalizer output (generated reports from external LLM calls)
llm_externalizer_output/

# TLDR artifacts
.tldrignore
.tldr_session_*
