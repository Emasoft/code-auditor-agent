#!/usr/bin/env python3
"""Pre-commit hook for claude-plugins-validation.

Validates plugin structure before allowing commits.

Exit codes from validate_plugin.py:
  0 - All checks passed
  1 - CRITICAL issues found (blocks commit)
  2 - MAJOR issues found (blocks commit)
  3 - MINOR issues found (allows commit with warning)
"""

import fnmatch
import os
import shutil
import subprocess
import sys
from pathlib import Path

# ANSI color codes, disabled when NO_COLOR is set or output is not a tty
def _colors_supported() -> bool:
    if os.environ.get("NO_COLOR"):
        return False
    if os.name == "nt":
        return bool(os.environ.get("WT_SESSION") or os.environ.get("ANSICON"))
    return hasattr(sys.stdout, "isatty") and sys.stdout.isatty()
_COLORS_SUPPORTED = _colors_supported()

RED = "\033[0;31m" if _COLORS_SUPPORTED else ""
YELLOW = "\033[1;33m" if _COLORS_SUPPORTED else ""
GREEN = "\033[0;32m" if _COLORS_SUPPORTED else ""
BLUE = "\033[0;34m" if _COLORS_SUPPORTED else ""
NC = "\033[0m" if _COLORS_SUPPORTED else ""

# Patterns that identify plugin-related files
PLUGIN_PATTERNS = [
    ".claude-plugin/*",
    "agents/*",
    "commands/*",
    "skills/*",
    "hooks/*",
    "scripts/*.py",
    "scripts/*.sh",
    "*.mcp.json",
]


def get_repo_root() -> Path:
    """Get the root directory of the git repository."""
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
        check=True,
    )
    return Path(result.stdout.strip())


def get_staged_files() -> list[str]:
    """Get list of staged files (added, copied, modified)."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
        capture_output=True,
        text=True,
    )
    # Return empty list on failure (matches bash `|| true` behavior)
    if result.returncode != 0:
        return []
    return [f for f in result.stdout.strip().splitlines() if f]


def is_plugin_file(filepath: str) -> bool:
    """Check if a file path matches any plugin-related pattern."""
    for pattern in PLUGIN_PATTERNS:
        if fnmatch.fnmatch(filepath, pattern):
            return True
    return False


def find_python_command() -> list[str]:
    """Find the best Python command to use: prefer `uv run python`, fall back to `python3`."""
    if shutil.which("uv") is not None:
        return ["uv", "run", "python"]
    return ["python3"]


def _run_cpv_sync(repo_root: Path) -> None:
    """Sync CPV scripts from upstream. Graceful: failures print a warning and do not block."""
    sync_script = repo_root / "scripts" / "sync_cpv_scripts.py"
    if not sync_script.exists():
        return
    python_cmd = find_python_command()
    try:
        result = subprocess.run(
            [*python_cmd, str(sync_script)],
            cwd=str(repo_root),
            capture_output=True,
            text=True,
            timeout=30,
        )
        if result.returncode != 0:
            print(f"{YELLOW}WARNING: CPV sync returned exit code {result.returncode}{NC}")
            if result.stderr.strip():
                print(f"{YELLOW}  {result.stderr.strip()}{NC}")
    except subprocess.TimeoutExpired:
        print(f"{YELLOW}WARNING: CPV sync timed out (30s) — continuing without sync{NC}")
    except FileNotFoundError:
        print(f"{YELLOW}WARNING: Could not run CPV sync (python/uv not found on PATH) — continuing{NC}")


def main() -> int:
    """Run pre-commit plugin validation. Returns 0 to allow commit, 1 to block."""
    try:
        repo_root = get_repo_root()
    except subprocess.CalledProcessError:
        print(f"{RED}ERROR: Failed to determine git repository root. Are you in a git repo?{NC}")
        return 1

    # Sync CPV scripts from upstream (non-blocking: failure does not prevent commit)
    _run_cpv_sync(repo_root)

    print(f"{BLUE}========================================{NC}")
    print(f"{BLUE}  Pre-commit Plugin Validation{NC}")
    print(f"{BLUE}========================================{NC}")

    # Get staged files
    staged_files = get_staged_files()

    if not staged_files:
        print(f"{GREEN}No staged files to validate.{NC}")
        return 0

    # Check if any plugin-related files are staged
    plugin_files = [f for f in staged_files if is_plugin_file(f)]

    if not plugin_files:
        print(f"{GREEN}No plugin files staged. Skipping validation.{NC}")
        return 0

    # Print each staged plugin file
    for filepath in plugin_files:
        print(f"  {BLUE}Staged:{NC} {filepath}")

    print()
    print(f"{BLUE}Running plugin validation...{NC}")
    print()

    # Run the plugin validator from the repo root
    validate_script = repo_root / "scripts" / "validate_plugin.py"
    if not validate_script.exists():
        print(f"{YELLOW}WARNING: Validation script not found at {validate_script}. Skipping validation.{NC}")
        return 0

    python_cmd = find_python_command()
    try:
        validation_result = subprocess.run(
            [*python_cmd, "scripts/validate_plugin.py", "."],
            cwd=str(repo_root),
            timeout=120,
        )
    except subprocess.TimeoutExpired:
        print(f"{RED}ERROR: Validation timed out after 120 seconds. Blocking commit.{NC}")
        return 1
    validation_exit_code = validation_result.returncode

    print()
    print(f"{BLUE}----------------------------------------{NC}")

    # Handle exit codes
    if validation_exit_code == 0:
        print(f"{GREEN}PASSED: All validation checks passed.{NC}")
        print(f"{GREEN}Commit allowed.{NC}")
        return 0
    elif validation_exit_code == 1:
        print(f"{RED}BLOCKED: CRITICAL issues found.{NC}")
        print(f"{RED}Fix critical issues before committing.{NC}")
        return 1
    elif validation_exit_code == 2:
        print(f"{RED}BLOCKED: MAJOR issues found.{NC}")
        print(f"{RED}Fix major issues before committing.{NC}")
        return 1
    elif validation_exit_code == 3:
        print(f"{YELLOW}WARNING: Minor issues found.{NC}")
        print(f"{GREEN}Commit allowed (minor issues only).{NC}")
        return 0
    else:
        print(f"{RED}ERROR: Validation script failed with exit code {validation_exit_code}{NC}")
        print(f"{RED}Please check the validation script.{NC}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
