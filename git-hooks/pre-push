#!/usr/bin/env python3
"""Pre-push hook for code-auditor-agent.

Performs full validation before allowing push:
1. Gate: reject pushes whose process ancestry does not include
   the real scripts/publish.py (verified by path + inode, not by
   env var — env vars are trivially spoofable, process trees are
   not).
2. Detect changed plugin files
3. Enforce version bump (local version must be > remote version)
4. Lint all files
5. Validate plugin via CPV remote execution (--strict)

Exit codes from cpv-remote-validate:
  0 - All checks passed
  1 - CRITICAL issues found (blocks push)
  2 - MAJOR issues found (blocks push)
  3 - MINOR issues found (blocks push)

Strict mode (default): ALL non-zero exit codes block push.
"""

import fnmatch
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

# ---------------------------------------------------------------------------
# ANSI color helpers (disabled on Windows unless colorama is available)
# ---------------------------------------------------------------------------


def _colors_supported() -> bool:
    """Return True when the terminal likely supports ANSI escape codes."""
    if os.environ.get("NO_COLOR"):
        return False
    if os.name == "nt":
        # On Windows, try to enable ANSI support via colorama
        try:
            import colorama  # noqa: F811

            colorama.init()
            return True
        except ImportError:
            return False
    # Unix-like systems: support ANSI if stdout is a terminal
    return hasattr(sys.stdout, "isatty") and sys.stdout.isatty()


_USE_COLOR = _colors_supported()

RED = "\033[0;31m" if _USE_COLOR else ""
YELLOW = "\033[1;33m" if _USE_COLOR else ""
GREEN = "\033[0;32m" if _USE_COLOR else ""
BLUE = "\033[0;34m" if _USE_COLOR else ""
NC = "\033[0m" if _USE_COLOR else ""  # No Color

# Patterns that identify plugin-related files
PLUGIN_PATTERNS = [
    ".claude-plugin/*",
    "agents/*",
    "commands/*",
    "skills/*",
    "hooks/*",
    "scripts/*.py",
    "scripts/*.sh",
    "*.mcp.json",
]

# The all-zeros SHA indicates branch creation / deletion in git hooks
ZERO_SHA = "0000000000000000000000000000000000000000"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def cprint(msg: str) -> None:
    """Print a message to stdout (handles encoding gracefully)."""
    print(msg, flush=True)


def get_repo_root() -> Path:
    """Return the absolute path to the git repository root."""
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
        check=True,
    )
    return Path(result.stdout.strip())


# ---------------------------------------------------------------------------
# Process ancestry gate
# ---------------------------------------------------------------------------


def _ps_lookup(pid: int) -> tuple[int, str] | None:
    """Return (ppid, full_command) for *pid*, or None if ps fails.

    Uses `ps -p PID -o ppid=,args=` which works on macOS and Linux.
    """
    try:
        r = subprocess.run(
            ["ps", "-p", str(pid), "-o", "ppid=,args="],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if r.returncode != 0 or not r.stdout.strip():
        return None
    parts = r.stdout.strip().split(None, 1)
    if len(parts) < 2:
        return None
    try:
        ppid = int(parts[0])
    except ValueError:
        return None
    return ppid, parts[1]


def _walk_process_ancestry(
    start_pid: int, max_depth: int = 20,
) -> list[tuple[int, str]]:
    """Walk up the process tree from *start_pid* (exclusive).

    Returns a list of (pid, command) tuples from the immediate parent
    up to init (PID 1) or until *max_depth* hops. Never includes the
    start_pid itself. Stops on loops or failed lookups.
    """
    ancestors: list[tuple[int, str]] = []
    seen: set[int] = set()
    info = _ps_lookup(start_pid)
    if info is None:
        return ancestors
    pid = info[0]
    for _ in range(max_depth):
        if pid <= 1 or pid in seen:
            break
        seen.add(pid)
        info = _ps_lookup(pid)
        if info is None:
            break
        ppid, cmd = info
        ancestors.append((pid, cmd))
        pid = ppid
    return ancestors


def _extract_script_paths(cmd: str) -> list[str]:
    """Return tokens from *cmd* that look like a '.py' script path.

    Uses shlex-style splitting to handle quoted arguments. Any token
    ending with '.py' is returned as a candidate.
    """
    import shlex
    try:
        tokens = shlex.split(cmd, posix=True)
    except ValueError:
        tokens = cmd.split()
    return [t for t in tokens if t.endswith(".py")]


def _same_file(a: Path, b: Path) -> bool:
    """Return True if *a* and *b* refer to the same filesystem inode."""
    try:
        sa = a.resolve().stat()
        sb = b.resolve().stat()
    except (OSError, FileNotFoundError):
        return False
    return (sa.st_dev, sa.st_ino) == (sb.st_dev, sb.st_ino)


def verify_publish_py_in_ancestry(repo_root: Path) -> tuple[bool, str]:
    """Return (ok, detail) where ok is True if publish.py is an ancestor.

    Walks the process tree starting from this hook's parent (git push)
    and looks for an ancestor whose argv contains a .py script whose
    resolved path matches repo_root/scripts/publish.py via inode.

    Inode comparison prevents spoofing by a user running their own
    script that happens to be named 'publish.py' — they'd need write
    access to scripts/publish.py itself to fool this check.
    """
    expected = repo_root / "scripts" / "publish.py"
    if not expected.is_file():
        return False, (
            f"scripts/publish.py not found at {expected}. "
            f"Cannot verify process ancestry."
        )

    ancestors = _walk_process_ancestry(os.getpid())
    if not ancestors:
        return False, "Could not walk process ancestry (ps failed?)"

    for pid, cmd in ancestors:
        for token in _extract_script_paths(cmd):
            # Resolve relative to the ancestor's cwd is hard without
            # /proc. Instead, try the token as-is (absolute), then
            # relative to repo_root.
            candidate = Path(token)
            if not candidate.is_absolute():
                candidate = repo_root / candidate
            if _same_file(candidate, expected):
                return True, (
                    f"publish.py verified in ancestor "
                    f"PID {pid}: {cmd[:100]}"
                )
    return False, (
        f"No publish.py ancestor found in {len(ancestors)} "
        f"ancestor process(es). Walked up to PID "
        f"{ancestors[-1][0]}."
    )


def find_python_command() -> list[str]:
    """Return the Python invocation command as a list of args.

    Prefers ``uv run python``; falls back to ``python3``.
    """
    try:
        subprocess.run(
            ["uv", "--version"],
            capture_output=True,
            text=True,
            check=True,
        )
        return ["uv", "run", "python"]
    except (FileNotFoundError, subprocess.CalledProcessError):
        return ["python3"]


def file_matches_plugin_patterns(filepath: str) -> bool:
    """Return True if *filepath* matches any of the plugin-related patterns."""
    # Normalise path separators to forward slashes for fnmatch
    normalised = filepath.replace(os.sep, "/")
    return any(fnmatch.fnmatch(normalised, pat) for pat in PLUGIN_PATTERNS)


def get_changed_files(local_sha: str, remote_sha: str) -> list[str]:
    """Return the list of files changed between *remote_sha* and *local_sha*."""
    if remote_sha == ZERO_SHA:
        # New branch push: the remote has nothing yet, so every file in
        # the pushed tree is "changed" from the remote's perspective.
        # Listing the full tree guarantees we never miss plugin changes
        # regardless of branch depth. (An earlier implementation diffed
        # against HEAD~10 — that silently skipped changes in commits
        # older than the 10th ancestor.)
        # -c core.quotepath=false: emit non-ASCII paths as UTF-8 literals
        # instead of the default octal-escaped, leading/trailing-quote form.
        # fnmatch in file_matches_plugin_patterns cannot match the quoted
        # form, so non-ASCII plugin filenames would silently bypass push-time
        # validation. Mirrors the fix already applied to pre-commit.
        result = subprocess.run(
            ["git", "-c", "core.quotepath=false", "ls-tree", "-r", "--name-only", local_sha],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip().splitlines()
    else:
        # Existing branch -- diff the range (same quotepath fix as above)
        try:
            result = subprocess.run(
                ["git", "-c", "core.quotepath=false", "diff", "--name-only", f"{remote_sha}..{local_sha}"],
                capture_output=True,
                text=True,
                check=True,
            )
            return result.stdout.strip().splitlines()
        except subprocess.CalledProcessError:
            return []


def run_script(
    python_cmd: list[str],
    script: Path,
    args: list[str] | None = None,
    timeout: int = 180,
    cwd: Path | None = None,
) -> int:
    """Run a Python script and return its exit code, streaming output."""
    cmd = [*python_cmd, str(script)]
    if args:
        cmd.extend(args)
    try:
        result = subprocess.run(cmd, timeout=timeout, cwd=str(cwd) if cwd else None)
        return result.returncode
    except subprocess.TimeoutExpired:
        print(f"  {YELLOW}TIMEOUT: {script.name} exceeded {timeout}s — skipping{NC}")
        return 0


def extract_version(filepath: Path) -> str | None:
    """Extract the ``version`` field from a JSON file, or return None."""
    try:
        data = json.loads(filepath.read_text(encoding="utf-8"))
        version: str | None = data.get("version")
        return version
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return None


def version_key(v: str) -> tuple[int, ...]:
    """Parse a ``X.Y.Z``-style version into a comparable tuple.

    Each segment contributes its leading digits (e.g. ``1.2.3-rc1`` →
    ``(1, 2, 3)``). This matches the documented contract: the hook must
    reject pushes whose local version is not strictly greater than the
    remote's. String equality alone missed downgrades (e.g. 1.1.0 → 1.0.0).
    """
    parts = []
    for seg in v.split("."):
        leading = ""
        for c in seg:
            if not c.isdigit():
                break
            leading += c
        parts.append(int(leading) if leading else 0)
    return tuple(parts)


# ---------------------------------------------------------------------------
# Main logic
# ---------------------------------------------------------------------------


def main() -> int:
    # ── Gate: reject pushes whose process ancestry does not include
    #     the real scripts/publish.py.
    #
    # This check walks the process tree (via `ps`) and verifies that
    # an ancestor process is running a script whose resolved path
    # (inode) matches this repo's scripts/publish.py file. It cannot
    # be spoofed by env vars, shell aliases, or a malicious script
    # named publish.py in a different directory — only the real
    # publish.py counts.
    repo_root = get_repo_root()
    ok, detail = verify_publish_py_in_ancestry(repo_root)
    if not ok:
        cprint(f"{RED}========================================{NC}")
        cprint(f"{RED}  BLOCKED: Direct git push is forbidden{NC}")
        cprint(f"{RED}========================================{NC}")
        cprint("")
        cprint(f"  Reason: {detail}")
        cprint("")
        cprint(f"  All pushes MUST go through the publish pipeline:")
        cprint(f"  {YELLOW}uv run python scripts/publish.py --patch{NC}")
        cprint(f"  (or --minor / --major)")
        cprint("")
        cprint(f"  The pipeline handles: version bump, README update,")
        cprint(f"  SKILL.md update, CHANGELOG, validation, commit,")
        cprint(f"  tag, push, and GitHub release — ensuring "
               f"marketplace auto-update.")
        cprint("")
        cprint(f"{RED}  Direct push bypasses critical steps and breaks{NC}")
        cprint(f"{RED}  the marketplace notification chain.{NC}")
        cprint(f"{RED}========================================{NC}")
        return 1

    cprint(f"{BLUE}========================================{NC}")
    cprint(f"{BLUE}  Pre-push Full Plugin Validation{NC}")
    cprint(f"{BLUE}========================================{NC}")
    cprint("")

    # The git pre-push hook receives REMOTE and URL as positional args
    remote = sys.argv[1] if len(sys.argv) > 1 else "<unknown>"
    url = sys.argv[2] if len(sys.argv) > 2 else "<unknown>"

    cprint(f"{BLUE}Pushing to:{NC} {remote} ({url})")
    cprint("")

    # Read stdin lines: each line is LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA
    plugin_files_changed = False
    stdin_lines = sys.stdin.read().strip().splitlines()

    for line in stdin_lines:
        parts = line.split()
        if len(parts) < 4:
            continue
        _local_ref, local_sha, _remote_ref, remote_sha = parts[:4]

        if local_sha == ZERO_SHA:
            # Branch deletion -- skip validation
            cprint(f"{GREEN}Branch deletion detected. No validation needed.{NC}")
            continue

        changed_files = get_changed_files(local_sha, remote_sha)

        for filepath in changed_files:
            if file_matches_plugin_patterns(filepath):
                plugin_files_changed = True
                break

    # If stdin was empty or only deletions, nothing to validate
    if not plugin_files_changed:
        cprint(f"{GREEN}No plugin files changed. Skipping full validation.{NC}")
        return 0

    # --- Version bump enforcement ---
    cprint(f"{BLUE}Checking version bump...{NC}")

    local_version = extract_version(repo_root / ".claude-plugin" / "plugin.json")
    if local_version:
        try:
            # Try origin/main first, fall back to origin/master
            remote_result = subprocess.run(
                ["git", "show", "origin/main:.claude-plugin/plugin.json"],
                capture_output=True, text=True, cwd=str(repo_root),
            )
            if remote_result.returncode != 0:
                remote_result = subprocess.run(
                    ["git", "show", "origin/master:.claude-plugin/plugin.json"],
                    capture_output=True, text=True, cwd=str(repo_root),
                )
            if remote_result.returncode == 0:
                remote_version = json.loads(remote_result.stdout).get("version")
                # Contract (module docstring): local version MUST be > remote
                # version. Raw equality check missed downgrades, so compare
                # parsed tuples and reject anything that isn't a strict bump.
                if remote_version and version_key(local_version) <= version_key(remote_version):
                    cprint(f"{RED}========================================{NC}")
                    cprint(f"{RED}  BLOCKED: Version not bumped!{NC}")
                    cprint(f"{RED}  Local: {local_version}  Remote: {remote_version}{NC}")
                    cprint(f"{RED}  Local version must be > remote version.{NC}")
                    cprint(f"{RED}  Run: uv run python scripts/publish.py --patch{NC}")
                    cprint(f"{RED}========================================{NC}")
                    return 1
                elif remote_version:
                    cprint(f"{GREEN}Version bump OK: {remote_version} → {local_version}{NC}")
                else:
                    cprint(f"{GREEN}Version: {local_version} (no remote version to compare){NC}")
            else:
                cprint(f"{GREEN}Version: {local_version} (first push){NC}")
        except Exception:
            cprint(f"{YELLOW}Could not check remote version — proceeding{NC}")
    else:
        cprint(f"{YELLOW}No local version found — skipping version check{NC}")

    cprint("")
    cprint(f"{BLUE}Running full plugin validation...{NC}")
    cprint("")

    python_cmd = find_python_command()
    CPV_REPO = "git+https://github.com/Emasoft/claude-plugins-validation"

    # --- Lint ---
    cprint(f"{BLUE}Running file linting...{NC}")
    cprint("")

    lint_script = repo_root / "scripts" / "lint_files.py"
    lint_exit = run_script(python_cmd, lint_script, [str(repo_root)], cwd=repo_root)

    if lint_exit != 0:
        cprint("")
        cprint(f"{RED}========================================{NC}")
        cprint(f"{RED}  BLOCKED: Linting issues found{NC}")
        cprint(f"{RED}  Fix lint issues before pushing.{NC}")
        cprint(f"{RED}========================================{NC}")
        return 1

    cprint("")
    cprint(f"{GREEN}Linting passed.{NC}")
    cprint("")

    # --- Validation via uvx remote execution (no local CPV scripts) ---
    if not shutil.which("uvx"):
        cprint(f"{RED}  BLOCKED: uvx not found — install uv{NC}")
        return 1

    try:
        validation_result = subprocess.run(
            [
                "uvx", "--from", CPV_REPO, "--with", "pyyaml",
                "cpv-remote-validate", "plugin", str(repo_root),
                "--verbose", "--strict",
            ],
            cwd=str(repo_root),
            timeout=180,
        )
        validation_exit = validation_result.returncode
    except subprocess.TimeoutExpired:
        cprint(f"{RED}  BLOCKED: CPV validation timed out (180s){NC}")
        return 1

    cprint("")
    cprint(f"{BLUE}----------------------------------------{NC}")

    # --- Marketplace version consistency ---
    marketplace_json = repo_root / "marketplace.json"
    if marketplace_json.is_file():
        cprint(f"{BLUE}Checking marketplace.json consistency...{NC}")

        plugin_json = repo_root / ".claude-plugin" / "plugin.json"
        if plugin_json.is_file():
            plugin_version = extract_version(plugin_json)
            marketplace_version = extract_version(marketplace_json)

            if plugin_version and marketplace_version:
                if plugin_version != marketplace_version:
                    cprint(f"{YELLOW}WARNING: Version mismatch!{NC}")
                    cprint(f"  plugin.json version: {plugin_version}")
                    cprint(f"  marketplace.json version: {marketplace_version}")
                    cprint(f"{YELLOW}Consider updating marketplace.json to match.{NC}")
                else:
                    cprint(f"{GREEN}Version consistency: OK ({plugin_version}){NC}")

    cprint("")

    # --- Handle validation exit codes ---
    if validation_exit == 0:
        cprint(f"{GREEN}========================================{NC}")
        cprint(f"{GREEN}  PASSED: All validation checks passed{NC}")
        cprint(f"{GREEN}  Push allowed.{NC}")
        cprint(f"{GREEN}========================================{NC}")
        return 0
    elif validation_exit == 1:
        cprint(f"{RED}========================================{NC}")
        cprint(f"{RED}  BLOCKED: CRITICAL issues found{NC}")
        cprint(f"{RED}  Fix ALL issues before pushing.{NC}")
        cprint(f"{RED}========================================{NC}")
        return 1
    elif validation_exit == 2:
        cprint(f"{RED}========================================{NC}")
        cprint(f"{RED}  BLOCKED: MAJOR issues found{NC}")
        cprint(f"{RED}  Fix ALL issues before pushing.{NC}")
        cprint(f"{RED}========================================{NC}")
        return 1
    elif validation_exit == 3:
        cprint(f"{YELLOW}========================================{NC}")
        cprint(f"{YELLOW}  BLOCKED: MINOR issues found{NC}")
        cprint(f"{YELLOW}  Fix ALL issues before pushing.{NC}")
        cprint(f"{YELLOW}========================================{NC}")
        return 1
    else:
        cprint(f"{RED}========================================{NC}")
        cprint(f"{RED}  ERROR: Validation failed (exit {validation_exit}){NC}")
        cprint(f"{RED}  Please check the validation script.{NC}")
        cprint(f"{RED}========================================{NC}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
