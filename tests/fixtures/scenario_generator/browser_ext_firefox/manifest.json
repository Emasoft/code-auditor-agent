{
  "manifest_version": 2,
  "name": "Example Firefox Extension",
  "version": "1.0.0",
  "description": "Fixture for browser_ext_firefox discoverer",
  "browser_specific_settings": {
    "gecko": {
      "id": "example@addons.mozilla.org",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://example.org/*"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Example"
  },
  "permissions": ["storage", "tabs"]
}
